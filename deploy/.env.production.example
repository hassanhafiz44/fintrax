# Production env template. Copy to /opt/fintrax/shared/.env on the server (it is
# symlinked into each release). Never commit the real file.
#
# SECURITY: regenerate APP_KEY before any real deploy — run
# `php artisan key:generate --show` (locally or on the server) and paste the
# result below.
APP_NAME=Fintrax
APP_ENV=production
APP_KEY=CHANGE_ME_RUN_ARTISAN_KEY_GENERATE
APP_DEBUG=false
APP_URL=https://fintrax.hassanpi.com

# Trusted reverse proxy: app sits behind host nginx on loopback only.
TRUSTED_PROXIES=127.0.0.1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=sqlite
DB_DATABASE=/opt/fintrax/shared/database/database.sqlite

# For MySQL/Postgres instead, comment the two lines above and use (DB_HOST is
# 127.0.0.1 — the app runs on the host, not in a container):
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=fintrax
# DB_USERNAME=fintrax
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@fintrax.hassanpi.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
